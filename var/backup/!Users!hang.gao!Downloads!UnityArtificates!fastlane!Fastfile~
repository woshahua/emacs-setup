fastlane_require 'date'
default_platform(:ios)

platform :ios do
  before_all do
    ENV["ASC_API_KEY_ID"] = "7Y6UC62RHK"
    ENV["ASC_API_ISSUER_ID"] = "69a6de87-5295-47e3-e053-5b8c7c11a4d1"
    ENV["ASC_API_KEY_FILEPATH"] = "./AppStoreConnectApiKey.p8"
    if !is_ci
      ensure_git_status_clean
    end
  end

  after_all do
  end

  lane :dev do
    cocoapods
    app_idntifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    build(
      export_method: 'enterprise',
      add_badge: true,
    )

    firebase_app_dist(
      app_id: "1:117498551537:ios:589eeb22803d22b3081d50"
    )
  end

  lane :qa do |options|
    cocoapods
    app_idntifier = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)

    build(
      export_method: 'enterprise',
      add_badge: true,
    )

    firebase_app_dist(
      app_id: "1:1024807455239:ios:5bc7d73e231895d99f38a2"
    )
  end


  private_lane :build do |options|
    export_method = [:export_method] || 'enterprise'
    add_badge = options[:add_badge] || false
    match_type = options[:match_type]

    match(type: {match_type}, readonly: is_ci)

    gym(
      scheme: 'Unity-iPhone',
      clean: true,
      silent: true,
      include_bitcode: false,
      # fix to relative path after determined
      workspace: 'Unity-iPhone.xcworkspace',
      output_directory: './',
      output_name: 'labit.ipa',
      export_method: export_method,
    )

    firebase_app_dist(
      app_id: "1:117498551537:ios:589eeb22803d22b3081d50"
    )
  end

  private_lane :update_badge do
    @commit_hash = Action.sh('git log -1 --format="%h"').strip
    @build_number = ENV['BITRISE_BUILD_NUMBER'] || Action.sh('git rev-list HEAD --count').strip
    add_badge(shield: "#{@build_number}-#{@commit_hash}-white", dark: true)
  end

  private_lane :firebase_app_dist do |options|
    app_id = options[:app_id]
    
    script = "../Script/make-release-note.sh"
    sh("cmd 755 #{script}")
    sh("git fetch origin")
    ote = sh("#{script} #{branch}")

    firebase_app_distribution(
      app: app_id,
      groups: "開発メンバー, QAメンバー, 企画メンバー",
      release_notes: note,
      firebase_cli_path: "./node_modules/.bin/firebase",
      firebase_cli_token: ENV["FIREBASE_TOKEN"]
    )
  end
end
